---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArtistCard from "../components/ArtistCard.astro";
import { getArtists } from "../lib/supabase";

const artists = await getArtists();
const featured = artists.slice(0, 6);
---

<BaseLayout
  title="Home"
  description="Rhyme Flow Music — Sello discografico independiente de musica urbana. Distribucion oficial via The Orchard. Descubre nuestro talento."
>

  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-neon-lime/5 via-transparent to-urban-black" />
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-neon-lime/3 rounded-full blur-[120px]" />

    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center py-20">
      <span class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime border border-neon-lime/20 rounded-full bg-neon-lime/5 mb-8">
        Distribucion Oficial The Orchard
      </span>

      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-black leading-[0.9] tracking-tight mb-6">
        <span class="text-urban-white">RHYME</span><br />
        <span class="text-gradient">FLOW MUSIC</span>
      </h1>

      <p class="max-w-2xl mx-auto text-lg md:text-xl text-urban-gray leading-relaxed mb-10">
        Sello discografico independiente de musica urbana. Descubrimos, impulsamos y distribuimos
        el talento que define el sonido de la nueva generacion.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/artistas"
          class="w-full sm:w-auto px-8 py-3.5 bg-neon-lime text-urban-black font-bold text-base rounded-xl hover:bg-neon-lime-dim transition-all duration-200 hover:glow-lime"
        >
          Ver artistas
        </a>
        <a
          href="/contacto"
          class="w-full sm:w-auto px-8 py-3.5 border border-white/20 text-urban-white font-medium text-base rounded-xl hover:bg-white/5 transition-all duration-200"
        >
          Contacto
        </a>
      </div>
    </div>
  </section>

  <!-- Misión / Visión -->
  <section class="relative py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
        <div>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime">Mision</span>
          <h2 class="mt-4 text-3xl sm:text-4xl font-display font-bold text-urban-white leading-tight">
            Impulsar el talento<br />urbano independiente
          </h2>
          <p class="mt-6 text-base text-urban-gray leading-relaxed">
            En Rhyme Flow Music creemos en el poder de la musica urbana para transformar realidades.
            Nuestra mision es descubrir, desarrollar y potenciar artistas emergentes del genero urbano,
            brindandoles las herramientas, la distribucion y el acompanamiento necesario para que su
            musica llegue a todos los rincones del mundo.
          </p>
        </div>
        <div>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">Vision</span>
          <h2 class="mt-4 text-3xl sm:text-4xl font-display font-bold text-urban-white leading-tight">
            Ser referentes del<br />urbano latino en Europa
          </h2>
          <p class="mt-6 text-base text-urban-gray leading-relaxed">
            Aspiramos a consolidarnos como el sello de referencia para la musica urbana latina en Europa,
            construyendo un ecosistema donde los artistas independientes encuentren un hogar creativo,
            soporte profesional y conexion directa con las principales plataformas digitales a traves
            de nuestra alianza con The Orchard.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Artistas destacados -->
  {
    featured.length > 0 && (
      <section class="py-24 lg:py-32 border-t border-white/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
            <div>
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime">
                Talento
              </span>
              <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold text-urban-white">
                Artistas destacados
              </h2>
            </div>
            <a
              href="/artistas"
              class="text-sm font-medium text-neon-lime hover:text-neon-lime-dim transition-colors flex items-center gap-1"
            >
              Ver todos los artistas
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>

          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((artist) => (
              <ArtistCard artist={artist} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Alianza The Orchard -->
  <section class="relative py-24 lg:py-32 border-t border-white/5">
    <div class="absolute inset-0 bg-gradient-to-r from-neon-lime/3 via-transparent to-gold/3" />
    <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">Alianza Estrategica</span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-display font-bold text-urban-white">
        Distribucion global via The Orchard
      </h2>
      <p class="mt-6 text-base text-urban-gray leading-relaxed">
        Nuestra alianza con The Orchard (Sony Music) nos permite distribuir la musica de nuestros
        artistas en mas de 250 plataformas digitales en todo el mundo: Spotify, Apple Music, Amazon
        Music, YouTube Music, Deezer, Tidal y muchas mas.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-8">
        <span class="text-2xl font-display font-bold text-urban-gray/40">Spotify</span>
        <span class="text-2xl font-display font-bold text-urban-gray/40">Apple Music</span>
        <span class="text-2xl font-display font-bold text-urban-gray/40">Amazon Music</span>
        <span class="text-2xl font-display font-bold text-urban-gray/40">YouTube Music</span>
        <span class="text-2xl font-display font-bold text-urban-gray/40">Deezer</span>
      </div>
    </div>
  </section>

  <!-- CTA -->{
    artists.length === 0 && (
      <section class="py-24 lg:py-32 border-t border-white/5">
        <div class="max-w-2xl mx-auto px-4 text-center">
          <h2 class="text-3xl font-display font-bold text-urban-white mb-4">
            Estamos construyendo el roster
          </h2>
          <p class="text-urban-gray mb-8">
            Pronto podras conocer a nuestros artistas. Mientras tanto, si tienes talento y
            quieres formar parte de Rhyme Flow Music, contactanos.
          </p>
          <a
            href="/contacto"
            class="inline-block px-8 py-3.5 bg-neon-lime text-urban-black font-bold text-base rounded-xl hover:bg-neon-lime-dim transition-all duration-200 hover:glow-lime"
          >
            Hablemos
          </a>
        </div>
      </section>
    )
  }

</BaseLayout>
