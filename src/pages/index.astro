---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroVisualizer from "../components/HeroVisualizer.astro";
import ArtistCard from "../components/ArtistCard.astro";
import { getArtists } from "../lib/supabase";

const artists = await getArtists();
const featured = artists.slice(0, 6);
---

<BaseLayout
  title="Home"
  description="Rhyme Flow Music — Sello discografico independiente de musica urbana. Descubre nuestro talento. Distribucion oficial via The Orchard."
>

  <!-- ═══════ HERO ═══════ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <HeroVisualizer />

    <!-- Gradient orbs -->
    <div class="absolute top-20 left-1/4 w-[600px] h-[600px] bg-neon-lime/4 rounded-full blur-[140px] pointer-events-none" />
    <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] bg-gold/3 rounded-full blur-[120px] pointer-events-none" />

    <!-- Dot grid texture -->
    <div
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style="background-image: radial-gradient(circle, #c4ff0e 1px, transparent 1px); background-size: 40px 40px;"
    ></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 text-center py-20">
      <!-- Badge with subtle bounce -->
      <div class="animate-float mb-10">
        <span
          class="inline-flex items-center gap-2 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime border border-neon-lime/20 rounded-full bg-neon-lime/5 backdrop-blur-sm"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-neon-lime animate-pulse"></span>
          Distribucion Oficial The Orchard
        </span>
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-black leading-[0.88] tracking-tight mb-8">
        <span class="text-urban-white block">RHYME</span>
        <span class="text-gradient glow-text-lime block">FLOW MUSIC</span>
      </h1>

      <p class="max-w-2xl mx-auto text-lg md:text-xl text-urban-gray/80 leading-relaxed mb-12 font-medium">
        Sello discografico independiente de musica urbana.<br class="hidden sm:block" />
        Descubrimos, impulsamos y distribuimos el talento que<br class="hidden sm:block" />
        define el sonido de la nueva generacion.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/artistas" class="btn-primary px-10 py-4 text-lg">
          Ver artistas
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/contacto" class="btn-ghost px-10 py-4 text-lg">
          Contacto
        </a>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-urban-gray/30">
      <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- ═══════ MISIÓN / VISIÓN ═══════ -->
  <section class="relative py-32 lg:py-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-2 lg:gap-24">

        <div class="reveal-left">
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime mb-6 block">Mision</span>
          <h2 class="text-4xl sm:text-5xl font-display font-black text-urban-white leading-[0.95] mb-6">
            Impulsar el talento<br />
            <span class="text-gradient">urbano independiente</span>
          </h2>
          <p class="text-base text-urban-gray/70 leading-relaxed max-w-lg">
            En Rhyme Flow Music creemos en el poder de la musica urbana para transformar realidades. Nuestra mision es descubrir, desarrollar y potenciar artistas emergentes, brindandoles las herramientas, la distribucion y el acompanamiento para que su musica llegue a todos los rincones del mundo.
          </p>
        </div>

        <div class="reveal-right">
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-6 block">Vision</span>
          <h2 class="text-4xl sm:text-5xl font-display font-black text-urban-white leading-[0.95] mb-6">
            Ser referentes del<br />
            <span class="text-gradient-reverse">urbano latino</span>
          </h2>
          <p class="text-base text-urban-gray/70 leading-relaxed max-w-lg">
            Aspiramos a consolidarnos como el sello de referencia para la musica urbana latina en Europa, construyendo un ecosistema donde los artistas independientes encuentren un hogar creativo, soporte profesional y conexion directa con las principales plataformas digitales.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ ARTISTAS DESTACADOS ═══════ -->
  {
    featured.length > 0 && (
      <section class="relative py-32 lg:py-40 border-t border-white/[0.04]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-16 reveal-up">
            <div>
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime block mb-3">Talento</span>
              <h2 class="text-4xl sm:text-5xl font-display font-black text-urban-white leading-[0.9]">
                Artistas<br />destacados
              </h2>
            </div>
            <a href="/artistas" class="btn-ghost text-sm gap-2">
              Ver todos
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>

          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((artist, i) => (
              <div style={`animation-delay: ${i * 0.15}s`} class="reveal-scale">
                <ArtistCard artist={artist} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ═══════ ALIANZA THE ORCHARD ═══════ -->
  <section class="relative py-32 lg:py-40 border-t border-white/[0.04] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-neon-lime/[0.02] via-transparent to-gold/[0.02] pointer-events-none" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] bg-neon-lime/[0.015] rounded-full blur-[150px] pointer-events-none" />

    <div class="relative z-10 max-w-3xl mx-auto px-4 text-center reveal-up">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold block mb-6">Alianza Estrategica</span>
      <h2 class="text-4xl sm:text-5xl font-display font-black text-urban-white leading-[0.9] mb-8">
        Distribucion global<br />via The Orchard
      </h2>
      <p class="text-base text-urban-gray/70 leading-relaxed mb-12 max-w-2xl mx-auto">
        Nuestra alianza con The Orchard (Sony Music) nos permite distribuir la musica de nuestros artistas en mas de 250 plataformas digitales en todo el mundo: Spotify, Apple Music, Amazon Music, YouTube Music, Deezer, Tidal y muchas mas.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10">
        {["Spotify", "Apple Music", "Amazon Music", "YouTube Music", "Deezer", "Tidal"].map((dsp) => (
          <span class="text-xl md:text-2xl font-display font-bold text-urban-gray/20 hover:text-urban-gray/40 transition-colors duration-300">
            {dsp}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ CTA ═══════ -->
  <section class="relative py-32 lg:py-40 border-t border-white/[0.04]">
    <div class="max-w-2xl mx-auto px-4 text-center reveal-up">
      <h2 class="text-3xl sm:text-4xl font-display font-black text-urban-white mb-6">
        ?Tienes talento?
      </h2>
      <p class="text-urban-gray/70 mb-10 text-lg">
        Buscamos artistas urbanos con identidad propia. Si crees que encajas en Rhyme Flow Music, hablemos.
      </p>
      <a href="/contacto" class="btn-primary px-10 py-4 text-lg animate-pulse-glow">
        Enviar demo
        <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
