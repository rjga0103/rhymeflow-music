---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroVisualizer from "../components/HeroVisualizer.astro";
import ArtistCard from "../components/ArtistCard.astro";
import { getArtists } from "../lib/supabase";

const artists = await getArtists();
const featured = artists.slice(0, 6);
---

<BaseLayout
  title="Home"
  description="Rhyme Flow Music — Sello discografico independiente de musica urbana. Descubre nuestro talento. Distribucion oficial via The Orchard."
>

  <!-- ═══════ HERO ═══════ -->
  <section class="relative min-h-[100svh] flex items-center justify-center overflow-hidden" data-particles>
    <HeroVisualizer />

    <!-- Orbs -->
    <div class="absolute top-20 left-1/4 w-[500px] sm:w-[700px] h-[500px] sm:h-[700px] bg-neon-lime/5 rounded-full blur-[150px] pointer-events-none animate-float-slow" />
    <div class="absolute bottom-20 right-1/4 w-[400px] sm:w-[600px] h-[400px] sm:h-[600px] bg-magenta/4 rounded-full blur-[130px] pointer-events-none animate-float-medium" style="animation-delay: -4s;" />
    <div class="absolute top-1/2 left-1/2 w-[300px] sm:w-[500px] h-[300px] sm:h-[500px] bg-cyan/3 rounded-full blur-[120px] pointer-events-none animate-float-fast" style="animation-delay: -2s;" />

    <!-- Grid texture -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none"
      style="background-image: radial-gradient(circle, #d4ff00 1px, transparent 1px); background-size: 36px 36px;">
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 text-center py-16 sm:py-24">
      <!-- Badge -->
      <div class="animate-float-medium mb-6 sm:mb-10">
        <span class="inline-flex items-center gap-2 px-3 sm:px-5 py-1.5 sm:py-2 text-[10px] sm:text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime border border-neon-lime/20 rounded-full bg-neon-lime/[0.04] backdrop-blur-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-neon-lime animate-pulse-glow"></span>
          Distribucion Oficial The Orchard
        </span>
      </div>

      <h1 class="text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-display font-black leading-[0.85] sm:leading-[0.85] tracking-tight mb-6 sm:mb-8 text-reveal">
        <span class="text-urban-white block">RHYME</span>
        <span class="text-gradient glow-text-lime block">FLOW MUSIC</span>
      </h1>

      <p class="max-w-xl sm:max-w-2xl mx-auto text-base sm:text-xl text-urban-gray/70 leading-relaxed mb-8 sm:mb-12 font-medium px-2">
        Sello independiente de musica urbana. Descubrimos, impulsamos y distribuimos
        el talento que define el sonido de la nueva generacion.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
        <a href="/artistas" class="btn-primary w-full sm:w-auto px-6 sm:px-10 py-3.5 sm:py-4 text-base sm:text-lg">
          Ver artistas
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/contacto" class="btn-ghost w-full sm:w-auto px-6 sm:px-10 py-3.5 sm:py-4 text-base sm:text-lg">
          Contacto
        </a>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 sm:bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-urban-gray/25">
      <span class="text-[10px] uppercase tracking-[0.3em]">Descubre</span>
      <svg class="w-3.5 h-3.5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>

  <!-- ═══════ COUNTERS ═══════ -->
  <section class="relative py-20 sm:py-28 border-t border-white/[0.04]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 sm:gap-12 text-center stagger-children">
        <div class="counter-reveal">
          <span id="counter-artists" data-target={artists.length} class="block text-4xl sm:text-5xl font-display font-black text-neon-lime glow-text-lime">0</span>
          <span class="text-sm text-urban-gray/50 mt-2 block uppercase tracking-wider">Artistas</span>
        </div>
        <div class="counter-reveal">
          <span class="block text-4xl sm:text-5xl font-display font-black text-gradient-gold">250+</span>
          <span class="text-sm text-urban-gray/50 mt-2 block uppercase tracking-wider">Plataformas</span>
        </div>
        <div class="counter-reveal">
          <span class="block text-4xl sm:text-5xl font-display font-black text-magenta">#1</span>
          <span class="text-sm text-urban-gray/50 mt-2 block uppercase tracking-wider">Objetivo</span>
        </div>
        <div class="counter-reveal">
          <span class="block text-4xl sm:text-5xl font-display font-black text-cyan">100%</span>
          <span class="text-sm text-urban-gray/50 mt-2 block uppercase tracking-wider">Independiente</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ MISIÓN / VISIÓN ═══════ -->
  <section class="relative py-24 sm:py-36 border-t border-white/[0.04]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-14 sm:gap-16 lg:grid-cols-2 lg:gap-24">

        <div class="reveal-left">
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime mb-4 sm:mb-6 block">Mision</span>
          <h2 class="text-3xl sm:text-5xl font-display font-black text-urban-white leading-[0.95] mb-5 sm:mb-6">
            Impulsar el talento<br />
            <span class="text-gradient">urbano independiente</span>
          </h2>
          <p class="text-sm sm:text-base text-urban-gray/60 leading-relaxed max-w-lg">
            En Rhyme Flow Music creemos en el poder de la musica urbana para transformar realidades.
            Nuestra mision es descubrir, desarrollar y potenciar artistas emergentes, brindandoles
            las herramientas y la distribucion para que su musica llegue a todos los rincones del mundo.
          </p>
        </div>

        <div class="reveal-right">
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-magenta mb-4 sm:mb-6 block">Vision</span>
          <h2 class="text-3xl sm:text-5xl font-display font-black text-urban-white leading-[0.95] mb-5 sm:mb-6">
            Ser referentes del<br />
            <span class="text-gradient-gold">urbano en Europa</span>
          </h2>
          <p class="text-sm sm:text-base text-urban-gray/60 leading-relaxed max-w-lg">
            Aspiramos a consolidarnos como el sello de referencia para la musica urbana en Europa,
            construyendo un ecosistema donde los artistas independientes encuentren un hogar creativo,
            soporte profesional y conexion directa con las principales plataformas digitales.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ ARTISTAS DESTACADOS ═══════ -->
  {
    featured.length > 0 && (
      <section class="relative py-24 sm:py-36 border-t border-white/[0.04]" data-particles>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3 sm:gap-4 mb-12 sm:mb-16 reveal-up">
            <div>
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-neon-lime block mb-3">Talento</span>
              <h2 class="text-3xl sm:text-5xl font-display font-black text-urban-white leading-[0.9]">
                Artistas destacados
              </h2>
            </div>
            <a href="/artistas" class="btn-ghost text-sm gap-2">
              Ver todos
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>

          <div class="grid gap-5 sm:gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((artist, i) => (
              <div style={`animation-delay: ${i * 0.12}s`} class="reveal-scale">
                <ArtistCard artist={artist} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ═══════ ALIANZA ═══════ -->
  <section class="relative py-24 sm:py-36 border-t border-white/[0.04] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-neon-lime/[0.03] via-transparent to-magenta/[0.03] pointer-events-none" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] sm:w-[900px] h-[600px] sm:h-[900px] bg-neon-lime/[0.02] rounded-full blur-[150px] pointer-events-none" />

    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 text-center reveal-up">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold block mb-4 sm:mb-6">Alianza Estrategica</span>
      <h2 class="text-3xl sm:text-5xl font-display font-black text-urban-white leading-[0.9] mb-6 sm:mb-8">
        Distribucion global<br />via The Orchard
      </h2>
      <p class="text-sm sm:text-base text-urban-gray/60 leading-relaxed mb-10 sm:mb-12 max-w-2xl mx-auto">
        Nuestra alianza con The Orchard (Sony Music) nos permite distribuir la musica de nuestros
        artistas en mas de 250 plataformas digitales en todo el mundo.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8">
        {["Spotify", "Apple Music", "Amazon", "YouTube", "Deezer", "Tidal"].map((dsp) => (
          <span class="text-lg sm:text-2xl font-display font-bold text-urban-gray/15 hover:text-urban-gray/35 transition-colors duration-300">
            {dsp}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ CTA ═══════ -->
  <section class="relative py-24 sm:py-36 border-t border-white/[0.04]">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center reveal-scale">
      <h2 class="text-3xl sm:text-4xl font-display font-black text-urban-white mb-4 sm:mb-6">
        ?Tienes talento?
      </h2>
      <p class="text-urban-gray/50 mb-8 sm:mb-10 text-base sm:text-lg">
        Buscamos artistas urbanos con identidad propia. Si crees que encajas en Rhyme Flow Music, hablemos.
      </p>
      <a href="/contacto" class="btn-primary px-8 sm:px-10 py-3.5 sm:py-4 text-base sm:text-lg animate-pulse-glow">
        Enviar demo
        <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const counter = document.getElementById("counter-artists");
  if (counter) {
    const target = parseInt(counter.getAttribute("data-target") || "0", 10);
    let current = 0;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const interval = setInterval(() => {
            current += Math.ceil(target / 30);
            if (current >= target) { current = target; clearInterval(interval); }
            counter.textContent = String(current);
          }, 50);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });
    observer.observe(counter);
  }
</script>
