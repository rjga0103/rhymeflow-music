<canvas
  id="hero-canvas"
  class="absolute inset-0 w-full h-full"
  aria-hidden="true"
></canvas>

<script>
  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
  if (!canvas) throw new Error("Canvas not found");

  const ctx = canvas.getContext("2d")!;
  let w = 0, h = 0;
  const bars = 60;
  const barData: number[] = [];
  const barTargets: number[] = [];
  const barColors: string[] = [];

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = canvas.width = canvas.offsetWidth * dpr;
    h = canvas.height = canvas.offsetHeight * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function randomTarget() { return Math.random() * 0.9 + 0.05; }

  const hues = [72, 72, 72, 72, 72, 320, 320, 185, 185, 50];
  for (let i = 0; i < bars; i++) {
    barData.push(0.05);
    barTargets.push(randomTarget());
    barColors.push(hues[Math.floor(Math.random() * hues.length)]);
  }

  let frame = 0;
  let targetOpacity = 0.35;
  let currentOpacity = 0.35;
  const isMobile = window.innerWidth < 768;

  function draw() {
    frame++;
    const displayW = canvas.offsetWidth;
    const displayH = canvas.offsetHeight;
    const barW = displayW / bars;
    const centerY = displayH * 0.55;

    ctx.clearRect(0, 0, displayW, displayH);

    // Target opacity based on mobile
    targetOpacity = isMobile ? 0.22 : 0.4;
    currentOpacity += (targetOpacity - currentOpacity) * 0.02;

    for (let i = 0; i < bars; i++) {
      if (frame % 6 === 0) barTargets[i] = randomTarget();
      barData[i] += (barTargets[i] - barData[i]) * 0.1;

      const barH = barData[i] * displayH * 0.45;
      const x = i * barW;
      const hue = barColors[i];
      const alpha = (0.2 + barData[i] * 0.6) * currentOpacity;

      // Upward bar
      const gradUp = ctx.createLinearGradient(x, centerY, x, centerY - barH);
      gradUp.addColorStop(0, `hsla(${hue}, 100%, 75%, ${alpha})`);
      gradUp.addColorStop(1, `hsla(${hue}, 100%, 55%, 0)`);
      ctx.fillStyle = gradUp;
      ctx.beginPath();
      ctx.roundRect(x + 1.5, centerY - barH, barW - 3, barH, [3]);
      ctx.fill();

      // Reflection
      const barH2 = barH * 0.3;
      const gradDown = ctx.createLinearGradient(x, centerY, x, centerY + barH2);
      gradDown.addColorStop(0, `hsla(${hue}, 100%, 75%, ${alpha * 0.35})`);
      gradDown.addColorStop(1, `hsla(${hue}, 100%, 55%, 0)`);
      ctx.fillStyle = gradDown;
      ctx.beginPath();
      ctx.roundRect(x + 1.5, centerY, barW - 3, barH2, [3]);
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  resize();
  draw();
  window.addEventListener("resize", () => { resize(); });
</script>
