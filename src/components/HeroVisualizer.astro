<canvas
  id="hero-canvas"
  class="absolute inset-0 w-full h-full opacity-30"
  aria-hidden="true"
></canvas>

<script>
  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
  if (!canvas) throw new Error("Canvas not found");

  const ctx = canvas.getContext("2d")!;
  let w = 0;
  let h = 0;
  const bars = 80;
  const barData: number[] = [];
  const barTargets: number[] = [];

  function resize() {
    w = canvas.width = canvas.offsetWidth * (window.devicePixelRatio || 1);
    h = canvas.height = canvas.offsetHeight * (window.devicePixelRatio || 1);
    ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
  }

  function randomTarget() {
    return Math.random() * 0.85 + 0.05;
  }

  for (let i = 0; i < bars; i++) {
    barData.push(0.05);
    barTargets.push(randomTarget());
  }

  let frame = 0;
  function draw() {
    frame++;
    const displayW = canvas.offsetWidth;
    const displayH = canvas.offsetHeight;
    const barW = displayW / bars;
    const centerY = displayH * 0.55;

    ctx.clearRect(0, 0, displayW, displayH);

    for (let i = 0; i < bars; i++) {
      if (frame % 8 === 0) barTargets[i] = randomTarget();
      barData[i] += (barTargets[i] - barData[i]) * 0.08;

      const barH = barData[i] * displayH * 0.5;
      const x = i * barW;
      const alpha = 0.25 + barData[i] * 0.65;
      const hue = 75 + Math.sin(i * 0.4 + frame * 0.02) * 20;

      // Upward bars
      const gradUp = ctx.createLinearGradient(x, centerY, x, centerY - barH);
      gradUp.addColorStop(0, `hsla(${hue}, 100%, 75%, ${alpha})`);
      gradUp.addColorStop(1, `hsla(${hue}, 100%, 60%, 0)`);
      ctx.fillStyle = gradUp;
      ctx.fillRect(x + 1, centerY - barH, barW - 2, barH);

      // Downward bars (reflection)
      const barH2 = barH * 0.35;
      const gradDown = ctx.createLinearGradient(x, centerY, x, centerY + barH2);
      gradDown.addColorStop(0, `hsla(${hue}, 100%, 75%, ${alpha * 0.4})`);
      gradDown.addColorStop(1, `hsla(${hue}, 100%, 60%, 0)`);
      ctx.fillStyle = gradDown;
      ctx.fillRect(x + 1, centerY, barW - 2, barH2);
    }

    requestAnimationFrame(draw);
  }

  resize();
  draw();
  window.addEventListener("resize", resize);
</script>
