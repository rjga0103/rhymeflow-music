---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-urban-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <span class="text-xl font-display font-bold">
          <span class="text-neon-lime">RF</span><span class="text-urban-white">MUSIC</span>
        </span>
        <p class="mt-3 text-sm text-urban-gray leading-relaxed max-w-xs">
          Sello discografico independiente. Distribucion oficial via The Orchard.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-urban-white uppercase tracking-wider mb-4">
          Navegacion
        </h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-urban-gray hover:text-neon-lime transition-colors">Home</a></li>
          <li><a href="/artistas" class="text-sm text-urban-gray hover:text-neon-lime transition-colors">Artistas</a></li>
          <li><a href="/contacto" class="text-sm text-urban-gray hover:text-neon-lime transition-colors">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-urban-white uppercase tracking-wider mb-4">
          Legal
        </h4>
        <ul class="space-y-2">
          <li><a href="/aviso-legal" class="text-sm text-urban-gray hover:text-neon-lime transition-colors">Aviso Legal</a></li>
          <li><a href="/politica-privacidad" class="text-sm text-urban-gray hover:text-neon-lime transition-colors">Politica de Privacidad</a></li>
          <li><a href="/politica-cookies" class="text-sm text-urban-gray hover:text-neon-lime transition-colors">Politica de Cookies</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-urban-gray">
        &copy; {year} Rhyme Flow Music. Todos los derechos reservados.
      </p>
      <p class="text-xs text-urban-gray">
        Distribuido por The Orchard
      </p>
    </div>
  </div>
</footer>
