---
---

<section id="contacto" class="relative">
  <div class="bg-urban-card border border-white/[0.05] rounded-2xl p-6 sm:p-8 lg:p-10">
    <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5 sm:space-y-6">
      <input type="hidden" name="access_key" value="TU_WEB3FORMS_KEY" />
      <input type="hidden" name="subject" value="Nuevo mensaje desde rhymeflowmusic.net" />
      <input type="hidden" name="from_name" value="Rhyme Flow Music Web" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none;" />

      <div>
        <label for="name" class="block text-sm font-medium text-urban-light mb-2">Nombre</label>
        <input type="text" id="name" name="name" required placeholder="Tu nombre o nombre artistico"
          class="w-full px-4 py-3 bg-surface border border-white/[0.06] rounded-xl text-urban-white placeholder:text-urban-gray/25 focus:outline-none focus:border-neon-lime/40 focus:ring-1 focus:ring-neon-lime/15 transition-all text-sm sm:text-base" />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-urban-light mb-2">Email</label>
        <input type="email" id="email" name="email" required placeholder="tu@email.com"
          class="w-full px-4 py-3 bg-surface border border-white/[0.06] rounded-xl text-urban-white placeholder:text-urban-gray/25 focus:outline-none focus:border-neon-lime/40 focus:ring-1 focus:ring-neon-lime/15 transition-all text-sm sm:text-base" />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-urban-light mb-2">Mensaje</label>
        <textarea id="message" name="message" required rows="5" placeholder="Cuentanos que necesitas..."
          class="w-full px-4 py-3 bg-surface border border-white/[0.06] rounded-xl text-urban-white placeholder:text-urban-gray/25 focus:outline-none focus:border-neon-lime/40 focus:ring-1 focus:ring-neon-lime/15 transition-all resize-none text-sm sm:text-base"></textarea>
      </div>

      <div class="flex items-start gap-3">
        <input type="checkbox" id="privacy" name="privacy" required
          class="mt-0.5 h-4 w-4 rounded border-white/10 bg-surface text-neon-lime focus:ring-neon-lime/15 shrink-0 cursor-pointer" />
        <label for="privacy" class="text-xs sm:text-sm text-urban-gray/50 leading-relaxed cursor-pointer">
          He leido y acepto la <a href="/politica-privacidad" class="text-neon-lime hover:underline">Politica de Privacidad</a> y consiento el tratamiento de mis datos.
        </label>
      </div>

      <button type="submit" class="btn-primary w-full text-sm sm:text-base">
        Enviar mensaje
        <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </button>
    </form>
  </div>
</section>
