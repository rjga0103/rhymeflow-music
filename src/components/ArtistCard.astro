---
interface Artist {
  id: string;
  name: string;
  slug: string;
  bio: string;
  photo_url: string;
  genre: string;
  dsp_links: {
    spotify?: string;
    apple?: string;
    youtube?: string;
    amazon?: string;
    deezer?: string;
    tidal?: string;
  };
}

const { artist } = Astro.props as { artist: Artist };
---

<a
  href={`/artistas/${artist.slug}`}
  class="group relative block rounded-2xl overflow-hidden bg-urban-card border border-white/5 hover:border-neon-lime/30 transition-all duration-500 hover:glow-lime"
>
  <div class="aspect-[3/4] relative overflow-hidden">
    <img
      src={artist.photo_url}
      alt={artist.name}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-urban-black via-urban-black/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500" />
    <div class="absolute bottom-0 left-0 right-0 p-5">
      <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-neon-lime/15 text-neon-lime border border-neon-lime/20 mb-3">
        {artist.genre}
      </span>
      <h3 class="text-xl font-display font-bold text-urban-white leading-tight">
        {artist.name}
      </h3>
    </div>
  </div>
</a>
